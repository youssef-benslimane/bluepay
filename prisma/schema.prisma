generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DemoBooking {
  id        Int      @id @default(autoincrement())
  date      String
  heure     String
  nom       String
  prenom    String
  email     String
  telephone String
  societe   String?
  createdAt DateTime @default(now())
}
